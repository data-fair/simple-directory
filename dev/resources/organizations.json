    }],
    "orgStorage": {
      "type": "ldap",
      "active": true,
      "config": {
        "url": "ldap://localhost:{LDAP_PORT}",
        "baseDN": "dc=example,dc=org",
        "searchUserDN": "cn=admin,dc=example,dc=org",
        "searchUserPassword": "admin",
        "users": {
          "objectClass": "inetOrgPerson",
          "dnKey": "cn",
          "mapping": {
            "id": "cn",
            "name": "cn",
            "email": "mail",
            "firstName": "givenName",
            "lastName": "sn"
          },
          "extraFilters": ["sn=Mouton"]
        },
        "members": {
          "role": {
            "attr": "employeeType",
            "values": {
              "admin": ["administrator"],
              "user": []
            },
            "default": "user"
          },
          "department": {
            "attr": "departmentNumber",
            "captureRegex": "^.*/(.*)$"
          }
        }
      }
    }
  }
